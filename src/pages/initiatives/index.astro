---
import '../../styles/dashboard.css';
import raw from '../../data/infrastructure/initiatives.json';

type RecordItem = Record<string, string>;
const records = raw as RecordItem[];
const clean = (value: unknown) => String(value || "").trim();
const show = (item: RecordItem) => {
  const raw = clean(item["Display on Dashboard"]).toLowerCase();
  return raw.includes("checked") || raw === "true" || raw === "yes" || raw === "1" || !("Display on Dashboard" in item);
};
const rank: Record<string, number> = { Critical: 1, High: 2, Medium: 3, Low: 4 };
const badgeClass = (value: string) => clean(value).toLowerCase().replace(/[^a-z0-9]+/g, "-");
const firstPresent = (item: RecordItem, fields: string[]) => {
  for (const field of fields) {
    const value = clean(item[field]);
    if (value) return value;
  }
  return "";
};
const shortText = (value: string, max = 125) => clean(value).length > max ? `${clean(value).slice(0, max)}…` : clean(value);
const fieldRows = (item: RecordItem, fields: string[]) =>
  fields.map((field) => ({ label: field, value: clean(item[field]) })).filter((row) => row.value);

const list = records
  .filter(show)
  .filter((item) => !["Completed", "Resolved", "Closed"].includes(clean(item.Status)))
  .sort((a, b) => (rank[clean(a.Priority)] ?? 99) - (rank[clean(b.Priority)] ?? 99));

const metaFields = ["Category","Priority","Status","Owner","Responsible Internal Party","Coordination Lead","Effort / Cost","Effort","Duration","Target Date","Next Action","Linked Decision","Linked Resource","External Resource","External Resource Required","Trigger Event","Can Be Deferred Until"];
const textFields = ["Notes","Description","Why This Matters","Institutional Impact","Failure Mode Prevented","Risk if Delayed","Deferred Rationale"];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Initiatives | Infrastructure OS</title>
  </head>
  <body>
    <main class="shell">
      <header class="topbar">
        <div>
          <p class="brand-kicker">Company Infrastructure OS</p>
          <h1>Initiatives</h1>
        </div>
        <nav class="nav">

          <a href="/">Overview</a>
          <a class='active' href="/initiatives/">Initiatives</a>
          <a  href="/decisions/">Decisions</a>
          <a  href="/questions/">Questions</a>
          <a  href="/resources/">Resources</a>
        </nav>
      </header>

      <section class="database">
        <div class="database-title">
          <div>
            <p class="eyebrow">Execution layer</p>
            <h2>Initiatives</h2>
          </div>

            <div class="toolbar">
              <button type="button" data-filter="all">All</button>
              <button type="button" data-filter="critical">Critical</button>
              <button type="button" data-filter="high">High</button>
              <button type="button" data-filter="medium">Medium</button>
              <button type="button" data-filter="low">Low</button>
            </div>
          </div>
        </div>

        <div class="table-head initiatives-head">
          <span>Priority</span><span>Initiative</span><span>Status</span><span>Owner</span><span>Next action</span>
        </div>

        <div class="db-list">
          {list.map((item) => (
            <details class={`db-row js-filter ${badgeClass(item.Priority)} ${badgeClass(item.Status)}`}>
              <summary class="row-grid initiatives-grid">
                <span><i class={`pill ${badgeClass(item.Priority)}`}>{item.Priority || "—"}</i></span>
                <strong>{item.Initiative}</strong>
                <span>{item.Status || "—"}</span>
                <span>{firstPresent(item, ["Owner", "Responsible Internal Party", "Coordination Lead"]) || "—"}</span>
                <span>{shortText(firstPresent(item, ["Next Action", "Notes", "Description"])) || "—"}</span>
              </summary>
              <div class="record-detail">
                <div class="record-meta">
                  {fieldRows(item, metaFields).map((row) => (
                    <div class="kv"><span>{row.label}</span><strong>{row.value}</strong></div>
                  ))}
                </div>
                <div class="record-text">
                  {fieldRows(item, textFields).map((row) => (
                    <section class="long-text"><h4>{row.label}</h4><p>{row.value}</p></section>
                  ))}

                    <section class="note-panel">
                      <h4>Add founder note</h4>
                      <form data-note-form>
                        <input type="hidden" name="relatedType" value={"Initiative"} />
                        <input type="hidden" name="relatedName" value={item.Initiative} />
                        <input type="hidden" name="priority" value={item.Priority} />

                        <label>
                          Note / feedback
                          <textarea name="note" placeholder="Add decision context, concern, correction, or instruction..." required></textarea>
                        </label>

                        <div class="note-actions">
                          <label>
                            Type
                            <select name="sentiment">
                              <option>Comment</option>
                              <option>Approval</option>
                              <option>Concern</option>
                              <option>Change Requested</option>
                              <option>Decision</option>
                            </select>
                          </label>

                          <label>
                            Submitted by
                            <input name="submittedBy" value="Founder" />
                          </label>

                          <button class="note-submit" type="submit">Save note</button>
                        </div>

                        <p class="note-status" data-note-status>Notes are saved into Airtable.</p>
                      </form>
                    </section>

                </div>
              </div>
            </details>
          ))}
        </div>

      </section>
    </main>

    <script>
      const buttons = document.querySelectorAll("[data-filter]");
      const rows = document.querySelectorAll(".js-filter");
      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const filter = button.getAttribute("data-filter");
          buttons.forEach((b) => b.classList.remove("active"));
          button.classList.add("active");
          rows.forEach((row) => {
            const visible = filter === "all" || row.className.includes(filter || "");
            row.style.display = visible ? "" : "none";
          });
        });
      });
      const allButton = document.querySelector("[data-filter='all']");
      if (allButton) allButton.classList.add("active");
    </script>

<script>
  document.querySelectorAll("[data-note-form]").forEach((form) => {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      const status = form.querySelector("[data-note-status]");
      const button = form.querySelector("button[type='submit']");
      const data = Object.fromEntries(new FormData(form).entries());

      data.currentUrl = window.location.href;

      if (status) {
        status.textContent = "Saving note...";
        status.className = "note-status";
      }

      if (button) button.disabled = true;

      try {
        const response = await fetch("/api/founder-note", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(data),
        });

        const responseText = await response.text();
        let result = {};

        try {
          result = responseText ? JSON.parse(responseText) : {};
        } catch {
          throw new Error(responseText || `Non-JSON response from server. HTTP ${response.status}.`);
        }

        if (!response.ok || !result.ok) {
          throw new Error(result.error || `Could not save note. HTTP ${response.status}.`);
        }

        form.reset();

        if (status) {
          status.textContent = "Saved to Airtable.";
          status.className = "note-status good";
        }
      } catch (error) {
        if (status) {
          status.textContent = error.message || "Could not save note.";
          status.className = "note-status bad";
        }
      } finally {
        if (button) button.disabled = false;
      }
    });
  });
</script>

  </body>
</html>
