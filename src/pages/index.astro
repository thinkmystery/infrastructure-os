---
import '../styles/dashboard.css';
import initiativesRaw from '../data/infrastructure/initiatives.json';
import decisionsRaw from '../data/infrastructure/decisions.json';
import questionsRaw from '../data/infrastructure/questions.json';
import resourcesRaw from '../data/infrastructure/resources.json';

type RecordItem = Record<string, string>;

const initiatives = initiativesRaw as RecordItem[];
const decisions = decisionsRaw as RecordItem[];
const questions = questionsRaw as RecordItem[];
const resources = resourcesRaw as RecordItem[];

const clean = (value: unknown) => String(value || "").trim();
const show = (item: RecordItem) => {
  const raw = clean(item["Display on Dashboard"]).toLowerCase();
  return raw.includes("checked") || raw === "true" || raw === "yes" || raw === "1" || !("Display on Dashboard" in item);
};

const visibleInitiatives = initiatives.filter(show);
const openInitiatives = visibleInitiatives.filter((item) => !["Completed", "Resolved", "Closed"].includes(clean(item.Status)));
const openDecisions = decisions.filter(show).filter((item) => !["Resolved", "Closed", "Completed"].includes(clean(item.Status)));
const openQuestions = questions.filter(show).filter((item) => !["Resolved", "Closed", "Completed"].includes(clean(item.Status)));
const activeResources = resources.filter((item) => clean(item.Name));

const rank: Record<string, number> = { Critical: 1, High: 2, Medium: 3, Low: 4 };
const badgeClass = (value: string) => clean(value).toLowerCase().replace(/[^a-z0-9]+/g, "-");
const firstPresent = (item: RecordItem, fields: string[]) => {
  for (const field of fields) {
    const value = clean(item[field]);
    if (value) return value;
  }
  return "";
};

const sortBy = (field: string) => (a: RecordItem, b: RecordItem) =>
  (rank[clean(a[field])] ?? 99) - (rank[clean(b[field])] ?? 99);

const quickWins = openInitiatives
  .filter((item) => ["Critical", "High"].includes(clean(item.Priority)))
  .filter((item) => ["Low", "Medium", ""].includes(clean(item["Effort / Cost"]) || clean(item.Effort)))
  .sort(sortBy("Priority"))
  .slice(0, 8);

const topInitiatives = openInitiatives.sort(sortBy("Priority")).slice(0, 6);
const topDecisions = openDecisions.sort(sortBy("Urgency")).slice(0, 5);
const topQuestions = openQuestions.sort(sortBy("Severity")).slice(0, 5);

const completion = visibleInitiatives.length
  ? Math.round((visibleInitiatives.filter((item) => ["Completed", "Resolved", "Closed"].includes(clean(item.Status))).length / visibleInitiatives.length) * 100)
  : 0;

const statusCounts = visibleInitiatives.reduce((acc: Record<string, number>, item) => {
  const key = clean(item.Status) || "Unclassified";
  acc[key] = (acc[key] || 0) + 1;
  return acc;
}, {});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Infrastructure OS</title>
  </head>

  <body>
    <main class="shell">
      <header class="topbar">
        <div>
          <p class="brand-kicker">Company Infrastructure OS</p>
          <h1>Command center</h1>
        </div>

        <nav class="nav">
          <a class="active" href="/">Overview</a>
          <a href="/initiatives/">Initiatives</a>
          <a href="/decisions/">Decisions</a>
          <a href="/questions/">Questions</a>
          <a href="/resources/">Resources</a>
        </nav>
      </header>

      <section class="card-grid">
        <a class="stat-card" href="/initiatives/"><span>Open initiatives</span><strong>{openInitiatives.length}</strong><em>execution queue</em></a>
        <a class="stat-card" href="/decisions/"><span>Open decisions</span><strong>{openDecisions.length}</strong><em>founder input needed</em></a>
        <a class="stat-card" href="/questions/"><span>Open questions</span><strong>{openQuestions.length}</strong><em>risk / ambiguity queue</em></a>
        <a class="stat-card" href="/resources/"><span>Resources</span><strong>{activeResources.length}</strong><em>external execution layer</em></a>
      </section>

      <section class="dashboard-grid">
        <div class="stack">
          <section class="panel">
            <div class="panel-header"><div><p class="eyebrow">Immediate operating focus</p><h2>Priority queue</h2></div><a class="button" href="/initiatives/">View all</a></div>
            <div class="panel-body stack">
              {topInitiatives.map((item) => (
                <a class="queue-card" href="/initiatives/">
                  <i class={`pill ${badgeClass(item.Priority)}`}>{item.Priority || "—"}</i>
                  <div><strong>{item.Initiative}</strong><p>{firstPresent(item, ["Next Action", "Notes", "Description"]) || "No next action listed"}</p></div>
                  <span>→</span>
                </a>
              ))}
            </div>
          </section>

          <section class="panel">
            <div class="panel-header"><div><p class="eyebrow">Founder input</p><h2>Decision queue</h2></div><a class="button" href="/decisions/">View all</a></div>
            <div class="panel-body stack">
              {topDecisions.map((item) => (
                <a class="queue-card" href="/decisions/">
                  <i class={`pill ${badgeClass(item.Urgency)}`}>{item.Urgency || "—"}</i>
                  <div><strong>{item.Decision}</strong><p>{item.Recommendation || item.Context || "No recommendation listed"}</p></div>
                  <span>→</span>
                </a>
              ))}
            </div>
          </section>

          <section class="panel">
            <div class="panel-header"><div><p class="eyebrow">Risk / ambiguity</p><h2>Open questions</h2></div><a class="button" href="/questions/">View all</a></div>
            <div class="panel-body stack">
              {topQuestions.map((item) => (
                <a class="queue-card" href="/questions/">
                  <i class={`pill ${badgeClass(item.Severity)}`}>{item.Severity || "—"}</i>
                  <div><strong>{item.Question}</strong><p>{item.Mitigation || item.Description || "No mitigation listed"}</p></div>
                  <span>→</span>
                </a>
              ))}
            </div>
          </section>
        </div>

        <aside class="side-stack">
          <section class="panel">
            <div class="panel-header"><div><p class="eyebrow">Readiness</p><h2>{completion}% complete</h2></div></div>
            <div class="panel-body"><div class="meter"><i style={`width:${completion}%`}></i></div><p class="home-note" style="margin-top:12px;">Founder notes are captured on each detailed record and written directly to Airtable.</p></div>
          </section>

          <section class="panel">
            <div class="panel-header"><div><p class="eyebrow">Quick wins</p><h2>Low-friction moves</h2></div></div>
            <div class="panel-body mini-list">
              {quickWins.map((item) => (
                <a class="mini-row" href="/initiatives/">
                  <span class={`dot ${badgeClass(item.Priority)}`}></span>
                  <strong>{item.Initiative}</strong>
                  <em>{firstPresent(item, ["Effort / Cost", "Effort"]) || "TBD"}</em>
                </a>
              ))}
            </div>
          </section>

          <section class="panel">
            <div class="panel-header"><div><p class="eyebrow">Operating shape</p><h2>Status</h2></div></div>
            <div class="panel-body breakdown">
              {Object.entries(statusCounts).map(([status, count]) => (
                <div class="bar-row"><span>{status}</span><div><i style={`width:${Math.max(8, (count / Math.max(1, visibleInitiatives.length)) * 100)}%`}></i></div><strong>{count}</strong></div>
              ))}
            </div>
          </section>
        </aside>
      </section>
    </main>
  </body>
</html>
